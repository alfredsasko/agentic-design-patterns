# Required for OpenAI examples, including the deep-research workflow.
OPENAI_API_KEY=your_openai_api_key_here

# Required for Gemini and Google ADK examples.
GOOGLE_API_KEY=your_google_api_key_here

# Optional alias accepted by one routing example.
GEMINI_API_KEY=your_gemini_api_key_here

# Set to true to make the deep-research example cheaper and faster during testing.
# It narrows the search context and asks for a shorter research pass.
OPENAI_DEEP_RESEARCH_FAST_TEST_MODE=false

# Retry settings for transient API failures such as 429 rate limits.
OPENAI_DEEP_RESEARCH_MAX_RETRIES=3
OPENAI_DEEP_RESEARCH_RETRY_BASE_DELAY_SECONDS=1.0
